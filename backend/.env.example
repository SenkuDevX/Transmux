# Transmux Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# Redis / Upstash (for job queue)
# Option 1: Full Redis URL (for self-hosted Redis)
# REDIS_URL=redis://localhost:6379

# Option 2: Upstash Redis (free tier)
UPSTASH_REDIS_HOST=your-upstash-host.upstash.io
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_PASSWORD=your-upstash-password

# Supabase (for job metadata storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudinary (for temporary file storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Admin Secret (for cleanup endpoint)
ADMIN_SECRET=your-secure-admin-secret

# Job Configuration
TEMP_DIR=/tmp/transmux
MAX_CONCURRENT_JOBS=2
JOB_TIMEOUT_MS=1800000
MAX_FILE_SIZE_MB=500
MAX_DURATION_SECONDS=3600
RATE_LIMIT_RPM=20
FILE_CLEANUP_HOURS=1
CLEANUP_INTERVAL_MINUTES=10

# yt-dlp binary path (usually just 'yt-dlp' if installed globally)
YTDLP_BIN=yt-dlp