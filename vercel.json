{
  "version": 2,
  "name": "transmux",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://transmux-backend.onrender.com",
    "NEXT_PUBLIC_WS_URL": "https://transmux-backend.onrender.com"
  }
}